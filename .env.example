# --- Database ---
# Postgres (via docker-compose). For a quick local run with no DB server,
# you can use SQLite instead, e.g.  DATABASE_URL=sqlite:///./dev.db
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/matching

# --- Gemini (the agent brain) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Matching / location ---
# named | gps | mixed  (mixed = generator randomly produces both kinds of requests)
LOCATION_MODE=mixed
CANDIDATE_TOP_N=10
MAX_RADIUS_KM=600

# --- Request generator ---
ENABLE_SCHEDULER=true
GENERATOR_MIN_MINUTES=1
GENERATOR_MAX_MINUTES=10
# Requests emitted per tick. Mean tick = 5.5 min -> ~262 ticks/day.
# batch=2 guarantees the spec's ">=400 requests/day".
GENERATOR_BATCH_SIZE=2
# Seed the vehicle fleet automatically on startup if the table is empty.
AUTO_SEED=true
